# Copier ce fichier en .env et remplir vos valeurs

# ── Deriv API ──────────────────────────────────────────────
DERIV_APP_ID=1089
# Token personnel Deriv (optionnel pour les données publiques)
# Créer un token sur : https://app.deriv.com/account/api-token
# Permissions requises : Read + Trade
DERIV_API_TOKEN=

# ── CORS — origines autorisées ─────────────────────────────
# En production, remplacer par l'URL réelle du frontend
# Plusieurs origines séparées par des virgules :
# ALLOWED_ORIGINS=["https://monapp.com","https://www.monapp.com"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
